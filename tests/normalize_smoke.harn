import { init, normalize_inbound, shutdown } from "../src/lib"
import { expect, expect_eq } from "./assertions"
import { assert_google_workspace_interface, drive_push_headers } from "./helpers"

pipeline default() {
  const token = "test-token"
  assert_google_workspace_interface()
  const event = normalize_inbound({channel_token: token, headers: drive_push_headers(token)})
  expect_eq(event.type, "event", "drive push envelope type")
  expect_eq(event.event.kind, "google_workspace.drive.update", "drive push event kind")
  expect_eq(event.event.signature_status.state, "verified", "drive push token verified")
  expect_eq(event.event.payload.provider, "google_workspace", "payload provider")
  expect_eq(event.event.payload.resource_id, "resource_123", "resource id")
  expect_eq(event.event.payload.channel_id, "chan_123", "channel id")
  expect_eq(event.event.payload.message_number, "42", "message number")
  expect(event.event.dedupe_key.contains("resource_123"), "dedupe key includes resource id")
  expect_eq(event.event.source_refs[0].kind, "drive_resource", "source ref kind")
  shutdown()
  const unsigned = normalize_inbound(
    {headers: drive_push_headers("", {"x-goog-channel-token": ""})},
  )
  expect_eq(unsigned.type, "event", "unsigned push can be accepted when no token configured")
  expect_eq(unsigned.event.signature_status.state, "unsigned", "unsigned state")
  init({channel_token: token})
  const bad_token = normalize_inbound({channel_token: token, headers: drive_push_headers("wrong")})
  expect_eq(bad_token.type, "reject", "wrong channel token rejects")
  expect_eq(bad_token.reject.status, 401, "wrong channel token status")
  const missing = normalize_inbound(
    {channel_token: token, headers: {"x-goog-channel-id": "chan_123"}},
  )
  expect_eq(missing.type, "reject", "missing resource id rejects")
  expect_eq(missing.reject.status, 400, "missing header status")
  shutdown()
}
